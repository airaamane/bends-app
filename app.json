{
  "expo": {
    "name": "MX5 Pocket",
    "slug": "bends-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bends-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.airaamane.bendsapp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MX5 Pocket uses your location to track your driving sessions and provide real-time road classification.",
        "NSMotionUsageDescription": "MX5 Pocket uses motion sensors to analyze your driving smoothness and provide feedback.",
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.airaamane.bendsapp",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A",
          "dark": {
            "backgroundColor": "#0A0A0A"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MX5 Pocket uses your location to track driving sessions.",
          "locationAlwaysPermission": "MX5 Pocket uses your location to track driving sessions.",
          "locationWhenInUsePermission": "MX5 Pocket uses your location to track driving sessions."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "MX5 Pocket uses motion sensors to analyze driving smoothness."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3e8dbe6-035d-469a-a6e1-58e7cbb5ab64"
      }
    },
    "owner": "airaamane",
    "updates": {
      "url": "https://u.expo.dev/d3e8dbe6-035d-469a-a6e1-58e7cbb5ab64"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
